generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role   @default(USER)
}

model RSVP {
  id           Int      @id @default(autoincrement())
  primaryGuest String
  email        String?
  side         String
  guestCount   Int
  guestNames   String
  events       String
  dietaryNotes String?
  createdAt    DateTime @default(now())
}
